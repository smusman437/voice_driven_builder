# Copy to `.env` and fill values: `cp .env.example .env`
#
# --- ElevenLabs (required) ---
# Get an API key: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Default voice / model (optional; sensible defaults are in app/settings.py)
# Free-tier note: avoid library voices; use a premade/public voice id.
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- LLM provider: mock | gemini | groq | openai | anthropic ---
# mock = no LLM API (template script; good for testing ElevenLabs + API wiring)
# gemini = Google AI Studio (free tier): https://aistudio.google.com/apikey
# groq = free-tier OpenAI-compatible API (https://console.groq.com/keys)
LLM_PROVIDER=mock
# Auto-fallback when primary provider is rate-limited/quota-exhausted.
# Options: none | mock | gemini | groq | openai | anthropic
LLM_FALLBACK_PROVIDER=mock

# Gemini — required if LLM_PROVIDER=gemini (use GEMINI_API_KEY or GOOGLE_API_KEY)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL_CANDIDATES=gemini-1.5-flash,gemini-1.5-flash-8b,gemini-2.0-flash

# Groq — required if LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (https://platform.openai.com/api-keys) — required if LLM_PROVIDER=openai (paid / credits)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (https://console.anthropic.com/settings/keys) — required if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Agent behavior ---
# AGENT_USE_TOOLS=true
# AGENT_MAX_TURNS=12

# --- Server ---
# LOG_LEVEL=INFO
# OUTPUT_DIR=outputs
